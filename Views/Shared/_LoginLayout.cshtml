<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Banking System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background-color: #F6F8F9;
            font-family: 'Outfit', sans-serif;
            margin: 0;
        }
        .main-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            width: 100%;
            padding: 20px 0;
        }
        .auth-container {
            width: 100%;
            max-width: 400px;
            padding: 15px;
            z-index: 10;
        }
        .auth-card {
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
            padding: 40px 30px;
            border: none;
        }
        .auth-title {
            font-weight: 700;
            font-size: 24px;
            text-align: center;
            margin-bottom: 5px;
            color: #1e293b;
        }
        .auth-subtitle {
            text-align: center;
            color: #64748b;
            font-size: 14px;
            margin-bottom: 30px;
        }
        .form-control {
            background-color: #F6F8F9;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 12px 16px;
            font-size: 14px;
        }
        .form-control:focus {
            box-shadow: 0 0 0 3px rgba(107, 78, 255, 0.15);
            border-color: #6B4EFF;
        }
        .form-label {
            font-weight: 600;
            color: #334155;
            font-size: 14px;
            margin-bottom: 6px;
        }
        .btn-primary {
            background-color: #6B4EFF;
            border-color: #6B4EFF;
            border-radius: 8px;
            padding: 12px;
            font-weight: 600;
            transition: all 0.2s;
        }
        .btn-primary:hover {
            background-color: #9990FF;
            border-color: #9990FF;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(107, 78, 255, 0.2);
        }
        .auth-links {
            text-align: center;
            margin-top: 20px;
            font-size: 14px;
            color: #64748b;
        }
        .auth-links a {
            color: #6B4EFF;
            font-weight: 600;
            text-decoration: none;
        }
        .auth-links a:hover {
            text-decoration: underline;
        }
        /* Hide Somee Ads */
        div[style*="position: fixed; z-index: 2147483647"], 
        div[style*="position:fixed;z-index:2147483647"],
        center > a[href*="somee.com"],
        body > div:last-child,
        #somee_ad_container {
            display: none !important;
            opacity: 0 !important;
            visibility: hidden !important;
            height: 0 !important;
            width: 0 !important;
            overflow: hidden !important;
        }
    </style>
</head>
<body>
    <div class="main-wrapper">
        <div class="auth-container">
            @RenderBody()
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
