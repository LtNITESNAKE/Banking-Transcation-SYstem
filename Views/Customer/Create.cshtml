@model Banking_Transcation_System.Models.AccountViewModel
@{
    ViewData["Title"] = "Add Customer";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-body p-4">
                <h3 class="fw-bold text-center mb-1">Add New Customer</h3>
                <p class="text-center text-muted mb-4">Fill in the details to create a new customer account.</p>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">First Name</label>
                            <input name="customer.FirstName" class="form-control" placeholder="John" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Last Name</label>
                            <input name="customer.LastName" class="form-control" placeholder="Doe" required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Email</label>
                            <input name="customer.Email" type="email" class="form-control" placeholder="john@example.com" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Phone</label>
                            <input name="customer.PhoneNumber" class="form-control" placeholder="0300-1234567" required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Username</label>
                            <input name="customer.Username" class="form-control" placeholder="johndoe" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Password</label>
                            <input name="customer.Password" type="password" class="form-control" placeholder="••••••••" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Address</label>
                        <input name="customer.Address" class="form-control" placeholder="123 Main St, City" required />
                    </div>

                    <hr class="my-4"/>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="AccountType" class="form-label fw-bold">Account Type</label>
                            <select asp-for="AccountType" class="form-select">
                                <option value="">Select Type</option>
                                <option value="Savings">Savings</option>
                                <option value="Checking">Checking</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Balance" class="form-label fw-bold">Initial Balance (PKR)</label>
                            <input asp-for="Balance" class="form-control" placeholder="0.00" />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-secondary px-4">Back</a>
                        <button type="submit" class="btn btn-primary px-4">Create Account</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
