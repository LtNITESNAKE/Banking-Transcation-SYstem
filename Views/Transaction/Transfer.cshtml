@model Banking_Transcation_System.Models.TransactionViewModel
@{
    ViewData["Title"] = "Transfer";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <div style="font-size: 2.5rem; color: #6B4EFF;">
                        <i class="bi bi-arrow-left-right"></i>
                    </div>
                    <h3 class="fw-bold mt-2">Fund Transfer</h3>
                    <p class="text-muted">Transfer money between accounts.</p>
                </div>

                <form asp-action="Transfer" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="AccountNumber" class="form-label fw-bold">From Account Number (Sender)</label>
                        <input asp-for="AccountNumber" class="form-control" placeholder="e.g. ACC-10023" />
                        <div id="senderNameResult" class="form-text mt-1"></div>
                        <span asp-validation-for="AccountNumber" class="text-danger"></span>
                    </div>

                    <div class="text-center my-2">
                        <i class="bi bi-arrow-down-circle fs-4 text-muted"></i>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ReceiverAccountNumber" class="form-label fw-bold">To Account Number (Receiver)</label>
                        <input asp-for="ReceiverAccountNumber" class="form-control" placeholder="e.g. ACC-10024" />
                        <div id="receiverNameResult" class="form-text mt-1"></div>
                        <span asp-validation-for="ReceiverAccountNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label fw-bold">Amount (PKR)</label>
                        <input asp-for="Amount" class="form-control" placeholder="0.00" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Remarks" class="form-label fw-bold">Remarks</label>
                        <input asp-for="Remarks" class="form-control" placeholder="Optional notes" />
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">Process Transfer</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            $('#AccountNumber').on('blur', function() {
                var accNum = $(this).val();
                if(accNum) {
                    $.get('/Transaction/GetAccountName', { accountNumber: accNum }, function(data) {
                        if(data.success) {
                            $('#senderNameResult').removeClass('text-danger').addClass('text-success fw-bold').text('Sender: ' + data.name);
                        } else {
                            $('#senderNameResult').removeClass('text-success fw-bold').addClass('text-danger').text('Account not found.');
                        }
                    });
                } else {
                    $('#senderNameResult').text('');
                }
            });

            $('#ReceiverAccountNumber').on('blur', function() {
                var accNum = $(this).val();
                if(accNum) {
                    $.get('/Transaction/GetAccountName', { accountNumber: accNum }, function(data) {
                        if(data.success) {
                            $('#receiverNameResult').removeClass('text-danger').addClass('text-success fw-bold').text('Receiver: ' + data.name);
                        } else {
                            $('#receiverNameResult').removeClass('text-success fw-bold').addClass('text-danger').text('Account not found.');
                        }
                    });
                } else {
                    $('#receiverNameResult').text('');
                }
            });
        });
    </script>
}
