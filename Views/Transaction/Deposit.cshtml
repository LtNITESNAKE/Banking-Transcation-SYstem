@model Banking_Transcation_System.Models.TransactionViewModel
@{
    ViewData["Title"] = "Deposit";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <div style="font-size: 2.5rem; color: #23C16B;">
                        <i class="bi bi-box-arrow-in-down"></i>
                    </div>
                    <h3 class="fw-bold mt-2">Deposit Funds</h3>
                    <p class="text-muted">Add money to an account.</p>
                </div>

                <form asp-action="Deposit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="AccountNumber" class="form-label fw-bold">Account Number</label>
                        <input asp-for="AccountNumber" class="form-control" placeholder="e.g. ACC-10023" />
                        <span asp-validation-for="AccountNumber" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label fw-bold">Amount (PKR)</label>
                        <input asp-for="Amount" class="form-control" placeholder="0.00" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Remarks" class="form-label fw-bold">Remarks</label>
                        <input asp-for="Remarks" class="form-control" placeholder="Optional notes" />
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg" style="background-color:#23C16B; border-color:#23C16B;">Process Deposit</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
